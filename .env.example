# Application Ports
PORT=5173
ELECTRON_RENDERER_URL=http://127.0.0.1:5173

# Internal API / Export Server Port
# Kameleo 版と並列起動する場合は 3001 以外 (例: 3002) を推奨
EXPORT_SERVER_PORT=3001

# Auth API Settings
AUTH_API_BASE=https://your-api-base-url.com/prod
AUTH_API_TIMEOUT_MS=5000

# Proxy / External API Keys (Templates)
# PROXY_TOKEN=YOUR_TOKEN_HERE
# TWILIO_ACCOUNT_SID=YOUR_SID_HERE
# TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
